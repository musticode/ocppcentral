# Local environment (example)
# Copy to .env.local (keep .env.local gitignored)

NODE_ENV=local

PORT=3000
HOST=localhost

MONGO_URI=mongodb://localhost:27017/ocppcentral

JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRES_IN=7d

OCPP_PORT=8080
OCPP_HOST=0.0.0.0
OCPP_PROTOCOL=ws

FRONTEND_URL=http://localhost:5173

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.local.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=local-session-secret-change-me

# API Keys (Optional)
GOOGLE_MAPS_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_CORS=true
ENABLE_RATE_LIMITING=false

# Monitoring (Optional)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
